# ============================================================
# Meeting Insights - Environment Configuration
# Copy this file to .env.local and fill in your values.
# ============================================================

# ------------------------------------------------------------
# LLM Provider
# ------------------------------------------------------------
# Options: anthropic | openai | local | claudecli | local-claudeapi | stub
MTNINSIGHTS_LLM_PROVIDER=anthropic

# Required if provider=anthropic
ANTHROPIC_API_KEY=

# Required if provider=openai
OPENAI_API_KEY=
OPENAI_MODEL=o3-mini

# Required if provider=local (Ollama)
MTNINSIGHTS_LOCAL_BASE_URL=http://localhost:11434
MTNINSIGHTS_LOCAL_MODEL=llama3.1:8b

# Required if provider=local-claudeapi
MTNINSIGHTS_CLAUDEAPI_URL=http://localhost:8100

# ------------------------------------------------------------
# Database & Storage Paths
# ------------------------------------------------------------
# SQLite database file
MTNINSIGHTS_DB_PATH=db/mtninsights.db

# LanceDB vector store directory
MTNINSIGHTS_VECTOR_PATH=db/lancedb

# Path to config/clients.json (override with custom path if needed)
# MTNINSIGHTS_CLIENTS_PATH=config/clients.json

# ------------------------------------------------------------
# API Server
# ------------------------------------------------------------
PORT=3000

# ------------------------------------------------------------
# Authentication
# ------------------------------------------------------------
# Set to 1 to require Bearer token auth on API routes
MTNINSIGHTS_AUTH_ENABLED=0

# Secret used to sign JWTs and verify the owner password on /oauth/authorize
# Generate with: openssl rand -base64 32
MTNINSIGHTS_OWNER_SECRET=

# API token used by the web dev UI (only needed if auth enabled)
VITE_API_TOKEN=

# ------------------------------------------------------------
# Logging
# ------------------------------------------------------------
# Options: error | warn | info | debug
MTNINSIGHTS_LOG_LEVEL=info

# ------------------------------------------------------------
# Search & Dedup Tuning (advanced, defaults usually fine)
# ------------------------------------------------------------
# MTNINSIGHTS_LLM_CHUNK_TOKEN_LIMIT=30000
# MTNINSIGHTS_DEDUP_SEMANTIC_THRESHOLD=0.80
# MTNINSIGHTS_DEDUP_STRING_THRESHOLD=0.90
